#include "xil_printf.h"
#include "xstatus.h"

#include "ap/StopWatch.h"

#include "common/delay/delay.h"
#include "common/interrupt/interrupt.h"

#include "HAL/TMR/TMR.h"
#include "HAL/I2C/I2C.h"

#include "driver/LCD_I2C/LCD_I2C.h"


/* ------------------------------------------------------------
 * I2C LCD raw communication test
 *
 * LCD address 0x27
 * Write address byte = 0x27 << 1 = 0x4E
 * ------------------------------------------------------------ */
static void LCD_RawI2CTest(void)
{
    I2C_Status_t status;
    uint8_t lcd_write_addr;

    lcd_write_addr = (uint8_t)(LCD_I2C_ADDR << 1U);

    xil_printf("\r\n");
    xil_printf("========================================\r\n");
    xil_printf("[RAW I2C LCD TEST]\r\n");
    xil_printf("LCD 7-bit addr : 0x%02X\r\n", LCD_I2C_ADDR);
    xil_printf("WRITE byte     : 0x%02X\r\n", lcd_write_addr);
    xil_printf("Initial SR     : 0x%08lx\r\n",
               (unsigned long)I2C0->SR);
    xil_printf("========================================\r\n");


    /* ---------------- START ---------------- */
    xil_printf("\r\n[1] START begin\r\n");

    status = I2C_Start(I2C0);

    xil_printf("[1] START end"
               " : status=%d, SR=0x%08lx\r\n",
               (int)status,
               (unsigned long)I2C0->SR);

    if (status != I2C_OK) {
        xil_printf("START failed. Stop test.\r\n");
        return;
    }


    /* ---------------- LCD address ----------------
     * 0x27 -> 0x4E
     */
    xil_printf("\r\n[2] ADDR 0x%02X begin\r\n", lcd_write_addr);

    status = I2C_WriteByte(I2C0, lcd_write_addr);

    xil_printf("[2] ADDR 0x%02X end"
               " : status=%d, SR=0x%08lx",
               lcd_write_addr,
               (int)status,
               (unsigned long)I2C0->SR);

    if (status == I2C_OK) {
        xil_printf(", ACK received\r\n");
    } else {
        xil_printf(", NACK or timeout\r\n");

        (void)I2C_Stop(I2C0);
        return;
    }


    /* ---------------- PCF8574 output byte ----------------
     * 0x08РК РЯЙнРћРЮ PCF8574 LCD backpackПЁМ­
     * backlight bitИИ Фв АЊРЬДй.
     *
     * ПЉБтМ­ЕЕ ACKАЁ ПЭОп
     * "СжМвИИ ACKЕЧАэ data writeАЁ НЧЦаЧЯДТ ЙЎСІ"АЁ ОЦДбСі ШЎРЮ АЁДЩ.
     */
    xil_printf("\r\n[3] PCF data 0x08 begin\r\n");

    status = I2C_WriteByte(I2C0, 0x08U);

    xil_printf("[3] PCF data 0x08 end"
               " : status=%d, SR=0x%08lx",
               (int)status,
               (unsigned long)I2C0->SR);

    if (status == I2C_OK) {
        xil_printf(", ACK received\r\n");
    } else {
        xil_printf(", NACK or timeout\r\n");
    }


    /* ---------------- STOP ---------------- */
    xil_printf("\r\n[4] STOP begin\r\n");

    status = I2C_Stop(I2C0);

    xil_printf("[4] STOP end"
               " : status=%d, SR=0x%08lx\r\n",
               (int)status,
               (unsigned long)I2C0->SR);


    xil_printf("\r\n");
    xil_printf("========================================\r\n");

    if (status == I2C_OK) {
        xil_printf("[RAW I2C LCD TEST END]\r\n");
    } else {
        xil_printf("[RAW I2C LCD TEST STOP FAIL]\r\n");
    }

    xil_printf("========================================\r\n");
}


/* ------------------------------------------------------------
 * Main
 * ------------------------------------------------------------ */
int main(void)
{
    int status;

    /* --------------------------------------------------------
     * Stopwatch peripheral initialization
     * -------------------------------------------------------- */
    StopWatch_Init();


    /* --------------------------------------------------------
     * I2C initialization
     *
     * СіБнРК raw polling testАЁ ИёРћРЬЙЧЗЮ
     * I2C interruptДТ РсНУ Ві ЛѓХТЗЮ АЫЛчЧбДй.
     * Timer interruptДТ АшМг ЛчПыЧбДй.
     * -------------------------------------------------------- */
    I2C_Init(I2C0);
    I2C_DisableInterrupt(I2C0);


    /* --------------------------------------------------------
     * Timer setup
     *
     * Input clock : 100 MHz АЁСЄ
     * PSC         : 100 - 1
     * ARR         : 1000 - 1
     *
     * 100 MHz / 100 / 1000 = 1 kHz
     * ЕћЖѓМ­ 1 msИЖДй TMR_ISR НЧЧр
     * -------------------------------------------------------- */
    TMR_SetPSC(TMR0, 100U - 1U);
    TMR_SetARR(TMR0, 1000U - 1U);
    TMR_SetCNT(TMR0, 0U);


    /* --------------------------------------------------------
     * Interrupt controller setup
     *
     * TMR_ISR:
     *   - FND_Execute()
     *   - incTick()
     *
     * I2C interruptДТ ПЌАсЕЧОю РжОюЕЕ,
     * РЇПЁМ­ I2C_DisableInterrupt()ИІ ЧпРИЙЧЗЮ
     * ЧіРч raw testПЁДТ ПЕЧтРЬ ОјДй.
     * -------------------------------------------------------- */
    status = SetupInterruptSystem();

    if (status != XST_SUCCESS) {
        xil_printf("\r\n[ERROR] Interrupt setup failed: %d\r\n", status);

        while (1) {
        }
    }


    /* Timer interrupt enable / timer start */
    TMR_StartInterrupt(TMR0);
    TMR_StartTimer(TMR0);


    xil_printf("\r\n");
    xil_printf("========================================\r\n");
    xil_printf("I2C LCD DEBUG PROGRAM START\r\n");
    xil_printf("LCD_I2C_ADDR = 0x%02X\r\n", LCD_I2C_ADDR);
    xil_printf("I2C BaseAddr = 0x%08lx\r\n",
               (unsigned long)I2C0);
    xil_printf("========================================\r\n");


    /* --------------------------------------------------------
     * Еќ Чб ЙјИИ I2C raw test МіЧр
     * -------------------------------------------------------- */
    LCD_RawI2CTest();


    /* --------------------------------------------------------
     * StopwatchДТ АшМг НЧЧр
     *
     * LCD РќУМ УЪБтШ­ Йз LCD_WriteLineРК ПЉБтМ­ НЧЧрЧЯСі ОЪДТДй.
     * ИеРњ serial logЗЮ I2C command sequenceКЮХЭ ШЎРЮЧбДй.
     * -------------------------------------------------------- */
    while (1) {
        StopWatch_Execute();
    }

    return 0;
}
