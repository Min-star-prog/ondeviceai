#include "xil_printf.h"
#include "xstatus.h"
#include <stdint.h>

#include "ap/StopWatch.h"
#include "common/delay/delay.h"
#include "common/interrupt/interrupt.h"

#include "HAL/TMR/TMR.h"
#include "HAL/I2C/I2C.h"

/*
 * axi_i2c.sv БтСи SR register bit
 *
 * SR[0] : busy
 * SR[1] : done_flag
 * SR[2] : ack_out
 *         0 = ACK
 *         1 = NACK
 * SR[3] : rx_valid_flag
 * SR[4] : irq_pending
 * SR[5] : irq_enable
 */
#define I2C_SR_BUSY_BIT       (1U << 0)
#define I2C_SR_DONE_BIT       (1U << 1)
#define I2C_SR_ACK_OUT_BIT    (1U << 2)


/* ------------------------------------------------------------
 * ЦЏСЄ I2C СжМвИІ РкММШї ШЎРЮЧЯДТ ЧдМі
 *
 * addr = 7-bit address
 * ПЙ)
 * 0x27 -> write address byte = 0x4E
 * 0x3F -> write address byte = 0x7E
 * ------------------------------------------------------------ */
static void I2C_Probe(uint8_t addr)
{
    I2C_Status_t st_start;
    I2C_Status_t st_write;
    I2C_Status_t st_stop;
    uint32_t sr;

    xil_printf("\r\n========================================\r\n");
    xil_printf("[I2C Probe : 7-bit address = 0x%02X]\r\n", addr);

    /* START condition */
    st_start = I2C_Start(I2C0);
    sr = I2C0->SR;

    xil_printf("START : status=%d, SR=0x%08lx\r\n",
               (int)st_start,
               (unsigned long)sr);

    if (st_start != I2C_OK) {
        xil_printf("-> START failed\r\n");
        return;
    }

    /*
     * LCD address write
     *
     * addr << 1:
     * 0x27 -> 0x4E
     * 0x3F -> 0x7E
     */
    st_write = I2C_WriteByte(I2C0, (uint8_t)(addr << 1));
    sr = I2C0->SR;

    xil_printf("WRITE : status=%d, SR=0x%08lx, ",
               (int)st_write,
               (unsigned long)sr);

    if ((sr & I2C_SR_ACK_OUT_BIT) == 0U) {
        xil_printf("ACK received\r\n");
    } else {
        xil_printf("NACK received\r\n");
    }

    /* STOP conditionРК write МКАј/НЧЦаПЭ АќАшОјРЬ ЧзЛѓ НЧЧр */
    st_stop = I2C_Stop(I2C0);
    sr = I2C0->SR;

    xil_printf("STOP  : status=%d, SR=0x%08lx\r\n",
               (int)st_stop,
               (unsigned long)sr);

    if ((st_write == I2C_OK) &&
        ((sr & I2C_SR_ACK_OUT_BIT) == 0U)) {
        xil_printf("-> Device detected at 0x%02X\r\n", addr);
    } else {
        xil_printf("-> No ACK at 0x%02X\r\n", addr);
    }
}


/* ------------------------------------------------------------
 * РќУМ 7-bit I2C address scan
 * РЯЙн I2C СжМв ЙќРЇ: 0x08 ~ 0x77
 * ------------------------------------------------------------ */
static void I2C_Scan(void)
{
    uint8_t addr;
    I2C_Status_t st_start;
    I2C_Status_t st_write;
    I2C_Status_t st_stop;
    uint32_t sr;
    uint8_t found_count = 0U;

    xil_printf("\r\n========================================\r\n");
    xil_printf("[I2C scan start]\r\n");

    for (addr = 0x08U; addr <= 0x77U; addr++) {
        /* START */
        st_start = I2C_Start(I2C0);

        if (st_start != I2C_OK) {
            xil_printf("START failed at address 0x%02X, status=%d, SR=0x%08lx\r\n",
                       addr,
                       (int)st_start,
                       (unsigned long)I2C0->SR);
            break;
        }

        /* address + write bit(0) РќМл */
        st_write = I2C_WriteByte(I2C0, (uint8_t)(addr << 1));
        sr = I2C0->SR;

        /* STOP */
        st_stop = I2C_Stop(I2C0);

        /*
         * I2C_WriteByte()АЁ I2C_OKРЬАэ,
         * ack_out = 0РЬИщ slaveАЁ ACKИІ КИГН АЭ
         */
        if ((st_write == I2C_OK) &&
            ((sr & I2C_SR_ACK_OUT_BIT) == 0U)) {
            xil_printf("ACK device found: 0x%02X\r\n", addr);
            found_count++;
        }

        if (st_stop != I2C_OK) {
            xil_printf("STOP failed at address 0x%02X, status=%d\r\n",
                       addr,
                       (int)st_stop);
            break;
        }
    }

    if (found_count == 0U) {
        xil_printf("No I2C device found.\r\n");
    } else {
        xil_printf("Total I2C device count: %d\r\n", found_count);
    }

    xil_printf("[I2C scan end]\r\n");
    xil_printf("========================================\r\n");
}


int main(void)
{
    /*
     * 1. БтСИ stopwatch / FND / LED / Button УЪБтШ­
     */
    StopWatch_Init();

    /*
     * 2. AXI I2C IP УЪБтШ­
     */
    I2C_Init(I2C0);

    /*
     * 3. Timer МГСЄ
     *
     * 100 MHz / (100 * 1000)
     * = 1 kHz
     * = 1 msИЖДй timer interrupt ЙпЛ§
     */
    TMR_SetPSC(TMR0, 100U - 1U);
    TMR_SetARR(TMR0, 1000U - 1U);
    TMR_SetCNT(TMR0, 0U);

    /*
     * 4. Interrupt Controller МГСЄ
     *
     * TMR_ISR:
     * - FND_Execute()
     * - incTick()
     *
     * I2C interruptДТ РЬЙј scanner ЕПРлПЁМ­ДТ ВіДй.
     */
    if (SetupInterruptSystem() != XST_SUCCESS) {
        xil_printf("Interrupt setup failed\r\n");
        return -1;
    }

    /*
     * 5. Timer interrupt НУРл
     * millis() БтЙн timeoutРЬ ЕПРлЧЯЗСИщ ЙнЕхНУ ЧЪПф
     */
    TMR_StartInterrupt(TMR0);
    TMR_StartTimer(TMR0);

    /*
     * 6. Scanner ДмАшПЁМ­ДТ I2C interruptИІ ЛчПыЧЯСі ОЪРН.
     * I2C done_flag polling ЙцНФРИЗЮ START/WRITE/STOP ПЯЗсИІ БтДйИАДй.
     */
    I2C_DisableInterrupt(I2C0);

    xil_printf("\r\n");
    xil_printf("========================================\r\n");
    xil_printf("I2C LCD Scanner Test Start\r\n");
    xil_printf("========================================\r\n");

    /*
     * АЁРх ШчЧб I2C LCD СжМв ЕЮ АГИІ ИеРњ ЛѓММ АЫЛч
     */
    I2C_Probe(0x27U);
    I2C_Probe(0x3FU);

    /*
     * РќУМ СжМв scan
     */
    I2C_Scan();

    /*
     * FND stopwatchДТ АшМг ЕПРлЧЯАд РЏСі.
     * LCD_Init(), LCD_WriteLine()РК РЬ scanner АЫСѕ ДмАшПЁМ­ДТ НЧЧрЧЯСі ОЪДТДй.
     */
    while (1) {
        StopWatch_Execute();
    }

    return 0;
}
