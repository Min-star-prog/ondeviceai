int main(void)
{
    StopWatch_Init();

    /* I2C IP ûòÝãàÙ */
    I2C_Init(I2C0);

    /* Timer: 100 MHz / 100 / 1000 = 1 ms */
    TMR_SetPSC(TMR0, 100U - 1U);
    TMR_SetARR(TMR0, 1000U - 1U);
    TMR_SetCNT(TMR0, 0U);

    if (SetupInterruptSystem() != XST_SUCCESS) {
        xil_printf("Interrupt setup failed\r\n");
        return -1;
    }

    /* FND refresh, millis()¢Š Timer interrupt¡¡ §úúÁ */
    TMR_StartInterrupt(TMR0);
    TMR_StartTimer(TMR0);

    /*
     * I2C interruptÇô ý— £µéôñö scanner §úúÁ
     * I2C done_flag pollingâ¡ñö ACK ¢ˋ¤ö àÛâö
     */
    I2C_DisableInterrupt(I2C0);

    I2C_Scan();

    while (1) {
        StopWatch_Execute();
    }

    return 0;
}
