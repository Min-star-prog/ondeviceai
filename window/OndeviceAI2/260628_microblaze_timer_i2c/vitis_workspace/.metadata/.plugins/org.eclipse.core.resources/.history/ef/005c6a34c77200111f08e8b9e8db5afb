static void I2C_Scan(void)
{
    uint8_t addr;
    I2C_Status_t status;

    xil_printf("\r\n[I2C scan start]\r\n");

    for (addr = 0x08U; addr <= 0x77U; addr++) {
        status = I2C_Start(I2C0);

        if (status != I2C_OK) {
            xil_printf("START fail: %d, SR=0x%08lx\r\n",
                       (int)status,
                       (unsigned long)I2C0->SR);
            return;
        }

        // 7-bit slave address + Write bit(0)
        status = I2C_WriteByte(I2C0, (uint8_t)(addr << 1));

        (void)I2C_Stop(I2C0);

        if (status == I2C_OK) {
            xil_printf("ACK device found: 0x%02X\r\n", addr);
        }
    }

    xil_printf("[I2C scan end]\r\n");
}
