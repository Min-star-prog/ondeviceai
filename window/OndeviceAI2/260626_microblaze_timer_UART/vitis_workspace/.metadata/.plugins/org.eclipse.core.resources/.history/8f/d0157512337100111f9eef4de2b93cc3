


#include "UART.h"


#include "xparameters.h"
#include <stdint.h>


typedef struct {
	uint32_t SR;
	uint32_t TDR;
	uint32_t RDR;
	uint32_t CR;
}UART_TypeDef_t;

#define UART_BASEADDR 	XPAR_UART_0_S00_AXI_BASEADDR
#define UART0			((UART_TypeDef_t *)UART_BASEADDR)



void UART_Transmit(UART_TypeDef_t *uart,uint32_t data )
{
	if(!(uart->SR & (1<<0)));
	uart->TDR =data;
}

uint32_t UART_Transmit(UART_TypeDef_t *uart,uint32_t data )
{
	if(!(uart->SR & (1<<0)));
	uart->TDR =data;
}
