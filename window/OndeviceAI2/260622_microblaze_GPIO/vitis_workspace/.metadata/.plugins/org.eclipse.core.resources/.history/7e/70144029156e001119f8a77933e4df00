#include "platform.h"
#include "xparameters.h"
#include "xil_io.h"
#include "sleep.h"
#include <stdint.h>

#define GPIOA_BASEADDR  XPAR_GPIO_0_S00_AXI_BASEADDR
#define GPIOB_BASEADDR  XPAR_GPIO_1_S00_AXI_BASEADDR

#define GPIO_CR_OFFSET   0x00
#define GPIO_ODR_OFFSET  0x08

int main()
{
    uint16_t led_data = 0x0001;
    int direction = 1;

    init_platform();

    Xil_Out32(GPIOA_BASEADDR + GPIO_CR_OFFSET, 0xFF);
    Xil_Out32(GPIOB_BASEADDR + GPIO_CR_OFFSET, 0xFF);

    while (1) {
        /* LED[0] ~ LED[7] */
        Xil_Out32(GPIOA_BASEADDR + GPIO_ODR_OFFSET,
                  led_data & 0x00FF);

        /* LED[8] ~ LED[15] */
        Xil_Out32(GPIOB_BASEADDR + GPIO_ODR_OFFSET,
                  (led_data >> 8) & 0x00FF);

        usleep(150000);

        if (led_data == 0x8000) {
            direction = -1;
        }
        else if (led_data == 0x0001) {
            direction = 1;
        }

        if (direction == 1) {
            led_data <<= 1;
        }
        else {
            led_data >>= 1;
        }
    }

    cleanup_platform();
    return 0;
}
