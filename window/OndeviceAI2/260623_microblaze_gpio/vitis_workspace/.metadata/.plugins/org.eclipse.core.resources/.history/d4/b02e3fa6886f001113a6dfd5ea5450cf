
#include "xil_printf.h"
#include "driver/LED/LED.h"
#include "driver/FND/FND.h"
#include "common/delay/delay.h"

int main()
{
	int counter = 0;
	uint16_t ledState = 1;

	LED_Init();
	FND_Init();

	uint32_t curTime;
	uint32_t prevTime = millis();
	while(1)
	{
		curTime = millis();
		if(curTime - prevTime >100) {
			prevTime = curTime;
		xil_printf("counter = %d\n", counter++);

		//ledState = (ledState << 1) | (ledState >> 15);	//ПоТЪ shift
		ledState = (ledState >> 1) | (ledState << 15);	//ПРИЅТЪ shift
		LED_WritePort16(ledState);

		FND_SetNum(1234);
		}
		//*****************polling service routine***********
		//РЬ ОЦЗЁТЪРК ЧзЛѓ ЕЙОЦОпЧЯДТ codeРг.
		FND_Execute();
		incTick();
		delay_ms(1);
	}
	return 0;
}

