#include <stdint.h>
#include "sleep.h"
#include "xil_printf.h"
#include "driver/LED/LED.h"

int main()
{
	int counter = 0;
	uint16_t ledState = 1;

	LED_Init();
	FND_Init();
	while(1)
	{
		xil_printf("counter = %d\n", counter++);

		//ledState = (ledState << 1) | (ledState >> 15);	//豭薹 shift
		ledState = (ledState >> 1) | (ledState << 15);	//螃艇薹 shift
		LED_WritePort16(ledState);

		FND_SetNum(1234);
		FND_Execute();
		usleep(1000);
	}
	return 0;
}

