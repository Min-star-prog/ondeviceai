wvSetCursor -win $_nWave2 1698.208626 -snap {("dut" 3)}
wvSetCursor -win $_nWave2 2500.658855 -snap {("dut" 3)}
wvSetCursor -win $_nWave2 1464.938210 -snap {("G2" 0)}
wvSetCursor -win $_nWave2 2496.075353
